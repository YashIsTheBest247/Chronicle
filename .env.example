# Chronicle — environment

# Postgres with the pgvector extension. Supabase and Neon both ship it.
# Supabase: Project Settings -> Database -> Connection string -> URI
# The schema (tables, HNSW vector index) is applied automatically on first run.
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Get free keys at https://aistudio.google.com/apikey
#
# One key works. Several are better: free-tier keys have low per-minute quotas,
# and Chronicle rotates across the pool, benching any key that returns 429 until
# it recovers. Three keys is roughly 3x the ceiling — worth it before a demo.
#
# Use whichever form suits you; all are read and de-duplicated:
GEMINI_API_KEY=
# GEMINI_API_KEYS=key_one,key_two,key_three
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Max upload size in MB. Defaults to 4 because Vercel rejects request bodies
# over 4.5 MB at the platform edge on every plan. Self-hosting (Render, a
# container) has no such cap — raise it there if you want larger scans.
# NEXT_PUBLIC_ because the upload screen shows the same number it enforces.
# NEXT_PUBLIC_MAX_UPLOAD_MB=4

# --- Google sign-in (required) ----------------------------------------------
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID
# (Web application). Authorised redirect URI:
#   http://localhost:3000/api/auth/callback/google        (local)
#   https://<your-app>.onrender.com/api/auth/callback/google  (deployed)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Any long random string: `openssl rand -base64 32`
AUTH_SECRET=
# Only needed if Auth.js guesses the origin wrong behind a proxy.
# AUTH_URL=https://your-app.onrender.com

# --- Telegram bot (optional) ------------------------------------------------
# Create a bot with @BotFather, then:
#   1. paste the token here
#   2. invent any random string for the webhook secret
#   3. deploy, then hit /api/telegram/setup?secret=<TELEGRAM_WEBHOOK_SECRET>
#   4. sign in to Chronicle -> Settings -> generate a code -> send it to the bot
#
# Access is per-account: a user signs in, opens Settings, and sends the
# 6-character code to the bot. There is no global allowlist — an unlinked chat
# can read nothing.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# Shown on the landing page's "Chat on Telegram" button, e.g. https://t.me/my_bot
NEXT_PUBLIC_TELEGRAM_URL=
