# Chronicle — environment

# Postgres with the pgvector extension. Supabase and Neon both ship it.
# Supabase: Project Settings -> Database -> Connection string -> URI
# The schema (tables, HNSW vector index) is applied automatically on first run.
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional overrides
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# --- Telegram bot (optional) ------------------------------------------------
# Create a bot with @BotFather, then:
#   1. paste the token here
#   2. invent any random string for the webhook secret
#   3. deploy, then hit /api/telegram/setup?secret=<TELEGRAM_WEBHOOK_SECRET>
#   4. message the bot; it replies with your chat ID — put it in the allowlist
#
# The allowlist is required. Chronicle has no accounts, so an empty allowlist
# denies everyone rather than exposing your documents to anyone who finds the bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=

# Shown on the landing page's "Chat on Telegram" button, e.g. https://t.me/my_bot
NEXT_PUBLIC_TELEGRAM_URL=
